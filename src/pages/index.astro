---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Writing about Bible software that people will actually use.</h1>
			<p>
				The Logos AI blog exists to explain product direction, offline-first reasoning, BYOK strategy, release
				notes, and the practical side of building AI Bible study tools that feel trustworthy.
			</p>
			<p>
				The product principle is simple: keep the free core useful, use the browser as the on-ramp, and charge
				for convenience instead of charging for the entire point of the app.
			</p>
			<h2>Latest posts</h2>
			<ul>
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`}>{post.data.title}</a>
					</li>
				))}
			</ul>
			<p>
				For product docs and setup help, head to <a href="https://docs.logos-ai.online">docs.logos-ai.online</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
