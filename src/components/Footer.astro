---
const today = new Date();
---

<footer class="footer-shell">
	<div class="footer-brand">
		<img src="/logos-logo.png" alt="Logos AI" width="56" height="56" class="footer-logo" />
		<div>
			<p class="footer-title">Logos AI Blog</p>
			<p class="footer-copy">
				Practical notes on Bible software, web and desktop releases, API.Bible setup, Ollama workflows, and AI study
				tools that stay useful in real life.
			</p>
		</div>
	</div>
	<div class="footer-links">
		<a href="https://logos-ai.online">Main site</a>
		<a href="https://docs.logos-ai.online">Docs</a>
		<a href="https://logos-ai.online/download">Download</a>
		<a href="https://github.com/jd4rider/logos">GitHub</a>
		<a href="https://github.com/sponsors/jd4rider">GitHub Sponsors</a>
		<a href="https://buymeacoffee.com/jd4rider">Buy Me a Coffee</a>
		<a href="mailto:jd4rider@gmail.com">Setup by email</a>
		<a href="tel:+14063967246">Call or text</a>
	</div>
	<p class="footer-meta">&copy; {today.getFullYear()} Logos AI. All rights reserved.</p>
</footer>
<style>
	.footer-shell {
		display: grid;
		gap: 1.5rem;
		padding: 2.5rem 1.25rem 4rem;
		border-top: 1px solid rgba(var(--gray-light), 0.12);
		background:
			linear-gradient(180deg, rgba(8, 17, 28, 0.2), rgba(4, 9, 18, 0.7)),
			rgba(4, 9, 18, 0.7);
	}
	.footer-brand {
		display: flex;
		align-items: center;
		gap: 1rem;
		max-width: 960px;
		width: calc(100% - 2rem);
		margin: 0 auto;
	}
	.footer-logo {
		flex: none;
		border-radius: 1rem;
		box-shadow: 0 0 22px rgba(245, 191, 82, 0.2);
	}
	.footer-title {
		margin: 0 0 0.4rem;
		font-family: "Fraunces", serif;
		font-size: 1.25rem;
		color: rgb(var(--gray-light));
	}
	.footer-copy {
		margin: 0;
		max-width: 48rem;
		font-size: 0.95rem;
		color: rgb(var(--gray));
	}
	.footer-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.8rem;
	}
	.footer-links a {
		display: inline-flex;
		align-items: center;
		padding: 0.7rem 1rem;
		border: 1px solid rgba(245, 191, 82, 0.22);
		border-radius: 999px;
		text-decoration: none;
		color: rgb(var(--gray-light));
		background: rgba(255, 255, 255, 0.03);
	}
	.footer-links a:hover {
		color: #ffd06d;
		border-color: rgba(245, 191, 82, 0.4);
	}
	.footer-meta {
		margin: 0;
		text-align: center;
		font-size: 0.9rem;
		color: rgb(var(--gray));
	}
	@media (max-width: 720px) {
		.footer-brand {
			align-items: flex-start;
		}
	}
</style>
